@model IEnumerable<RoomManagement.Models.Bill>

@{
    ViewData["title"] = "Quản lý hóa đơn";
    Layout = "_layout";
}

<div>
    <div class="actionBar">
        <div class="addRoom">
            <a asp-action="Create"><i class="fa-solid fa-circle-plus"></i> Tạo</a>
        </div>
        <div class="searchRoom">
            <input type="text" name="search" class="ajax-filter" placeholder="Tìm tên phòng, mã người thuê...">
            <button type="button" id="btnFilter"><i class="fa-solid fa-magnifying-glass"></i></button>
        </div>
        <div class="fillRoom">
            <i class="fa-solid fa-filter"></i>
            <select name="status" class="ajax-filter">
                <option value="">-- Chọn trạng thái --</option>
                <option value="Chưa thanh toán">Chưa thanh toán</option>
                <option value="Đã thanh toán">Đã thanh toán</option>
            </select>
        </div>
    </div>
    <div class="listRoom" id="table-container">
        @await Html.PartialAsync("_BillTable", Model)

        <div class="d-flex justify-content-center mt-3">
            
        </div>
    </div>
</div>