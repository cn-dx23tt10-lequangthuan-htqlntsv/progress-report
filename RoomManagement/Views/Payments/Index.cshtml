@model IEnumerable<RoomManagement.Models.Payment>

@{
    ViewData["Title"] = "Quản lý thanh toán";
    Layout = "_Layout";
}

<div>
    <div class="actionBar">
        <div class="addRoom">
            <a asp-action="Create"><i class="fa-solid fa-circle-plus"></i> Thêm</a>
        </div>
        <div class="searchRoom">
            <input type="text" name="search" class="ajax-filter" placeholder="Tìm mã thanh toán hoặc mã hóa đơn...">
            <button type="button" id="btnFilter"><i class="fa-solid fa-magnifying-glass"></i></button>
        </div>
        <div class="fillRoom">
            <i class="fa-solid fa-filter"></i>
            <select name="paymentMethod" class="ajax-filter">
                <option value="">-- Chọn phương thức --</option>
                <option value="Chuyển khoản">Chuyển khoản</option>
                <option value="Tiền mặt">Tiền mặt</option>
            </select>
        </div>
    </div>

    <div class="listRoom" id="table-container">
        @await Html.PartialAsync("_PaymentTable", Model)

        <div class="d-flex justify-content-center mt-3">
        </div>
    </div>
</div>