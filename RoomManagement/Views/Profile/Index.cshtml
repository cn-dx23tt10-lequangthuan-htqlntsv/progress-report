@model RoomManagement.Models.User

@{
    ViewData["title"] = "Hồ sơ";
    Layout = "_layout";
}

<div class="avatar">
    @if(string.IsNullOrEmpty(Model.Image))
    {
        <img src="~/imgs/avt.jpg" id="previewAvatar" alt="Ảnh đại diện">
    }
    else
    {
        <img src="~/uploads/@Model.Image" id="previewAvatar" alt="Ảnh đại diện">
    }
</div>

<div class="changImage">
    <input type="file" id="fileInput" name="uploadFile" style="display: none;" onchange="previewImage(this)" />
    <button type="button" id="preImg" onclick="document.getElementById('fileInput').click()">Thay đổi ảnh</button>
    <button type="button" style="display: none;" id="upImg" onclick="uploadAvatar()">Lưu ảnh</button>
</div>

<div class="info">
    <div class="left">
        <form asp-action="ChangeInfo" asp-route-id="@Model.Id" method="post">
            <div>
                <label>Tên:</label>
                <input type="text" asp-for="Name" value="@Model.Name" />
            </div>
            <div>
                <label>Email:</label>
                <input type="email" asp-for="Email" value="@Model.Email" />
            </div>
            <div>
                <label>Số điện thoại:</label>
                <input type="text" minlength="10" maxlength="10" asp-for="Phone" value="@Model.Phone" />
            </div>
            <div>
                <label>Vai trò:</label>
                <input type="text" asp-for="Role" value="@(Model.Role == "admin" ? "Quản trị viên" : "Nhân viên")" style="cursor: not-allowed; opacity: 0.inherit; background-color: #ccc;" readonly />
            </div>
            <div>
                <label>Ngày tạo tài khoản:</label>
                <input type="date" asp-for="CreatedAt" value="@Model.CreatedAt?.ToString("yyyy-MM-dd")" style="cursor: not-allowed; opacity: 0.inherit; background-color: #ccc;" readonly />
            </div>
            <div class="btnProfile">
                <button type="submit" style="color: blue;">Cập nhật</button>
            </div>
        </form>
    </div>
    <div class="right">
        <form asp-action="ChangePassword" asp-route-id="@Model.Id" method="post">
            <h3>Thay đổi mật khẩu</h3>

            <div class="pass">
                <label for="">Mật khẩu củ:</label>
                <input type="password" name="oldPass" id="OP" placeholder="Mật khẩu củ...">
                <i class="fa-solid fa-eye" onclick="showPass('OP', this)"></i>
            </div>
            <div class="pass">
                <label for="">Mật khẩu mới:</label>
                <input type="password" asp-for="Password" id="NP" placeholder="Mật khẩu mới...">
                <i class="fa-solid fa-eye" onclick="showPass('NP', this)"></i>
            </div>
            <div class="pass">
                <label for="">Xác nhận mật khẩu:</label>
                <input type="password" asp-for="ConfirmPassword" id="CP" placeholder="Nhập lại mật khẩu mới...">
                <i class="fa-solid fa-eye" onclick="showPass('CP', this)"></i>
            </div>
            <div class="btnChangePass">
                <button type="submit">Đổi mật khẩu</button>
            </div>
        </form>
    </div>
</div>