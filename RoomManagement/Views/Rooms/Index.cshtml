@model IEnumerable<RoomManagement.Models.Room>

@{
    ViewData["Title"] = "Quản lý phòng";
    Layout = "_Layout";
}

<div>
    <div class="actionBar">
        <div class="addRoom">
            <a asp-controller="Rooms" asp-action="Create"><i class="fa-solid fa-circle-plus"></i> Thêm</a>
        </div>
        <div class="searchRoom">
            <input type="text" name="search" class="ajax-filter" placeholder="Tìm mã phòng hoặc tên phòng...">
            <button type="button" id="btnFilter"><i class="fa-solid fa-magnifying-glass"></i></button>
        </div>
        <div class="fillRoom">
            <i class="fa-solid fa-filter"></i>
            <select name="status" class="ajax-filter">
                <option value="">-- Chọn trạng thái --</option>
                <option value="Trống">Còn trống</option>
                <option value="Đã thuê">Đã thuê</option>
            </select>
        </div>
    </div>

    <div class="listRoom" id="table-container">
        @await Html.PartialAsync("_RoomTable", Model)

        <div class="d-flex justify-content-center mt-3">
        </div>
    </div>
</div>